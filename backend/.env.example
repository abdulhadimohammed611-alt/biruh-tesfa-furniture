# =============================================================================
# BIRUH TESFA Furniture — Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# SERVER
# ---------------------------------------------------------------------------
PORT=5000
NODE_ENV=production

# Public URL of this backend service (used for Chapa webhooks, upload URLs).
# Render example: https://biruh-tesfa-backend.onrender.com
BACKEND_URL=https://your-backend-name.onrender.com

# ---------------------------------------------------------------------------
# DATABASE — Neon / Render PostgreSQL (production)
# ---------------------------------------------------------------------------
# Preferred: full connection string (Neon provides this).
# When DATABASE_URL is set, the individual DB_* vars below are ignored.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Fallback: individual vars (used only when DATABASE_URL is NOT set — local dev)
DB_USER=postgres
DB_HOST=localhost
DB_PASSWORD=your_local_password
DB_DATABASE=biruh_tesfa_furniture
DB_PORT=5432

# ---------------------------------------------------------------------------
# AUTHENTICATION
# ---------------------------------------------------------------------------
# Use a long, random, secret string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_secret

# ---------------------------------------------------------------------------
# CORS — Frontend origin(s)
# ---------------------------------------------------------------------------
# The URL of your deployed frontend. Comma-separate multiple origins.
# Vercel example: https://biruh-tesfa.vercel.app
# Custom domain:  https://biruhtesfa.com
# Multiple:       https://biruh-tesfa.vercel.app,https://biruhtesfa.com
FRONTEND_URL=https://your-frontend.vercel.app

# ---------------------------------------------------------------------------
# PAYMENTS — Stripe
# ---------------------------------------------------------------------------
# Get from https://dashboard.stripe.com/apikeys
# Use sk_test_... for test mode, sk_live_... for production
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# ---------------------------------------------------------------------------
# PAYMENTS — Chapa (Ethiopian payment gateway)
# ---------------------------------------------------------------------------
# Get from https://dashboard.chapa.co
# Use CHASECK_TEST-... for test, CHASECK-... for production
CHAPA_SECRET_KEY=CHASECK_TEST-your_chapa_secret_key_here
CHAPA_WEBHOOK_SECRET=your_chapa_webhook_secret_here

# ---------------------------------------------------------------------------
# PAYMENTS — Telebirr (set to false when live integration is ready)
# ---------------------------------------------------------------------------
TELEBIRR_MOCK=true

# ---------------------------------------------------------------------------
# FILE UPLOADS — Cloudinary (production)
# ---------------------------------------------------------------------------
# Get from https://console.cloudinary.com
# When these three vars are set, uploads go to Cloudinary CDN.
# Leave all three empty to fall back to local disk storage (dev only).
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
